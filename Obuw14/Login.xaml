<Window x:Class="Obuw14.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Obuw14"
        mc:Ignorable="d"
        Background="#FFFFFF"
        FontFamily="Arial"
        WindowStartupLocation="CenterScreen"
        Title="Авторизация" Height="450" Width="400">
    <StackPanel Margin="15" VerticalAlignment="Center">
        <TextBlock Text="Авторизация" Margin="0,0,0,20" HorizontalAlignment="Center" FontSize="18" FontWeight="Bold"/>
        <TextBlock Text="Логин"/>
        <TextBox x:Name="txtLogin" Margin="0,0,0,10"/>
        <TextBlock Text="Пароль"/>
        <PasswordBox x:Name="txtParol" Margin="0,0,0,20"/>

        <Button Click="Knopka1" Content="Войти" Background="LightGreen" Height="30" Margin="0,0,0,20"/>
        <Button Click="Knopka2" Content="Войти как гость" Background="Green" Height="30" Margin="0,0,0,20"/>

    </StackPanel>
</Window>
