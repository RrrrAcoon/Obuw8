<Window x:Class="Obuw14.OknoZakazi"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:m="clr-namespace:Obuw14.Modeli"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Obuw14"
           Background="#FFFFFF"
           FontFamily="Arial"
           WindowStartupLocation="CenterScreen"
        mc:Ignorable="d"
        Title="Закази" Height="500" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="LightGreen">
           
            <Image Source="/Icon.png" />
            <Button Width="80" Content="Назад" Click="Nazad" Margin="10,10"/>
            <Button Width="80" Click="Dobavit" x:Name="BthDobavit" Content="Добавить" Margin="5"/>
            <Button Width="80" Click="Redakt" x:Name="BthRedakt" Content="Изменить" Margin="5"/>
            <Button Width="80" Click="Udalit" x:Name="BthUdalit" Content="Удалить" Margin="5"/>
        </StackPanel>

        

        <ListView Grid.Row="1" x:Name="LvElement" HorizontalContentAlignment="Stretch" Margin="10" MouseDoubleClick="ClickLv">
            <ListView.ItemTemplate>
                <DataTemplate  >
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="5">
                            <TextBlock Text="{Binding Id,StringFormat='Артикул заказа{0}'}" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="{Binding StatusZakaza.Nazvanie,StringFormat='Статус заказа: {0}'}"/>
                            <TextBlock Text="{Binding PunktVidachi.Adres,StringFormat='Адрес пункта выдачи: {0}'}"/>
                            <TextBlock Text="{Binding DataZakaza,StringFormat='Дата заказа: {0:dd.MM.yyyy}'}"/>
                    </StackPanel>
                        <TextBlock Text="{Binding DataVidachi,StringFormat='Дата выдачи: {0:dd.MM.yyyy}'}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </StackPanel>

                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
